{
    "name": "@sinemacula/web-core",
    "version": "1.0.0",
    "description": "Framework-agnostic kernel shared by every Sine Macula frontend: configuration, HTTP, routing, modules, i18n and storage.",
    "license": "Apache-2.0",
    "author": "Ben Carey <bdmc@sinemacula.co.uk>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sinemacula/web-core-ts.git"
    },
    "homepage": "https://github.com/sinemacula/web-core-ts#readme",
    "bugs": {
        "url": "https://github.com/sinemacula/web-core-ts/issues"
    },
    "keywords": ["sine macula", "vue", "kernel", "frontend", "framework", "typescript", "modular"],
    "type": "module",
    "engines": {
        "node": ">=22"
    },
    "packageManager": "npm@11.11.0",
    "exports": {
        "./eslint": "./eslint/index.js",
        "./app/create-web-core-app": "./src/app/create-web-core-app.ts",
        "./app/services": "./src/app/services.ts",
        "./composables/use-focus-trap": "./src/composables/use-focus-trap.ts",
        "./config/web-environment": "./src/config/web-environment.ts",
        "./i18n/application-i18n": "./src/i18n/application-i18n.ts",
        "./module/module": "./src/module/module.ts",
        "./notifications/confirm-service": "./src/notifications/confirm-service.ts",
        "./notifications/toast-service": "./src/notifications/toast-service.ts",
        "./query/use-list-query": "./src/query/use-list-query.ts",
        "./query/use-resource": "./src/query/use-resource.ts",
        "./router/navigation-progress": "./src/router/navigation-progress.ts",
        "./session/authorization": "./src/session/authorization.ts",
        "./session/create-session-module": "./src/session/create-session-module.ts",
        "./session/middleware": "./src/session/middleware.ts",
        "./session/redirect": "./src/session/redirect.ts",
        "./session/session-context": "./src/session/session-context.ts",
        "./session/session-store": "./src/session/session-store.ts"
    },
    "files": ["dist", "eslint", "!eslint/**/__tests__/**", "!eslint/vitest.config.mjs", "README.md", "LICENSE"],
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "workspaces": ["playground"],
    "scripts": {
        "dev": "npm run dev --workspace playground",
        "build": "npm run build --workspace playground",
        "build:dist": "node scripts/build.mjs",
        "prepack": "node scripts/build.mjs && node scripts/pack-exports.mjs dist",
        "preview": "npm run preview --workspace playground",
        "typecheck": "vue-tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:mutation": "stryker run",
        "test:mutation:eslint": "stryker run stryker.eslint.config.json",
        "mutation:scope": "node scripts/mutation-scope.mjs",
        "check": "qlty check",
        "fmt": "qlty fmt",
        "smells": "qlty smells",
        "deadcode": "knip",
        "lint:structure": "eslint --no-config-lookup --no-inline-config --config eslint.structure.mjs src playground/src e2e",
        "test:eslint": "vitest run --config eslint/vitest.config.mjs",
        "check:pkg": "rm -rf .pack && mkdir -p .pack && npm pack --pack-destination .pack --silent && publint .pack/*.tgz && attw .pack/*.tgz --profile esm-only --exclude-entrypoints ./eslint",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "size": "npm run size --workspace playground",
        "postpack": "node scripts/pack-exports.mjs src"
    },
    "peerDependencies": {
        "@typescript-eslint/utils": "^8",
        "eslint": ">=9",
        "pinia": ">=3",
        "typescript-eslint": "^8",
        "vue": ">=3.5",
        "vue-eslint-parser": ">=10",
        "vue-i18n": ">=11",
        "vue-router": ">=4"
    },
    "peerDependenciesMeta": {
        "@typescript-eslint/utils": {
            "optional": true
        },
        "eslint": {
            "optional": true
        },
        "typescript-eslint": {
            "optional": true
        },
        "vue-eslint-parser": {
            "optional": true
        }
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "^0.18.5",
        "@axe-core/playwright": "^4.11.3",
        "@playwright/test": "^1.60.0",
        "@sinemacula/coding-standards": "^1.13.0",
        "@size-limit/file": "^12.1.0",
        "@stryker-mutator/core": "^9.6.1",
        "@stryker-mutator/vitest-runner": "^9.6.1",
        "@types/node": "^25.9.3",
        "@typescript-eslint/rule-tester": "^8.64.0",
        "@typescript-eslint/utils": "^8.64.0",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vitest/coverage-v8": "^4.1.8",
        "eslint": "^10.7.0",
        "happy-dom": "^20.10.2",
        "knip": "^6.16.1",
        "mkdist": "^2.4.1",
        "publint": "^0.3.21",
        "size-limit": "^12.1.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.64.0",
        "vite": "^8.0.16",
        "vitest": "^4.1.8",
        "vue-eslint-parser": "^10.0.0",
        "vue-tsc": "^3.3.4"
    },
    "overrides": {
        "brace-expansion": "^5.0.7",
        "fast-uri": "^3.1.3",
        "qs": "6.15.2"
    }
}
