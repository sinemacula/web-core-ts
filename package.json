{
    "name": "@sinemacula/web-core",
    "version": "1.0.0",
    "description": "Framework-agnostic kernel shared by every Sine Macula frontend: configuration, HTTP, routing, modules, i18n and storage.",
    "private": true,
    "type": "module",
    "license": "Apache-2.0",
    "author": "Sine Macula Limited",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sinemacula/web-core-ts.git"
    },
    "engines": {
        "node": ">=22.23.1"
    },
    "packageManager": "npm@11.18.0",
    "exports": {
        "./*": "./src/*.ts"
    },
    "workspaces": ["playground"],
    "scripts": {
        "dev": "npm run dev --workspace playground",
        "build": "npm run build --workspace playground",
        "preview": "npm run preview --workspace playground",
        "typecheck": "vue-tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:mutation": "stryker run",
        "check": "qlty check",
        "fmt": "qlty fmt",
        "smells": "qlty smells",
        "deadcode": "knip",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "size": "npm run size --workspace playground"
    },
    "peerDependencies": {
        "pinia": ">=3.0.4",
        "vue": ">=3.5.39",
        "vue-i18n": ">=11.4.6",
        "vue-router": ">=4.6.4"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.12.1",
        "@playwright/test": "^1.61.1",
        "@size-limit/file": "^12.1.0",
        "@stryker-mutator/core": "^9.6.1",
        "@stryker-mutator/vitest-runner": "^9.6.1",
        "@types/node": "^25.9.5",
        "@vitejs/plugin-vue": "^6.0.8",
        "@vitest/coverage-v8": "^4.1.10",
        "happy-dom": "^20.10.6",
        "knip": "^6.27.0",
        "size-limit": "^12.1.0",
        "typescript": "^6.0.3",
        "vite": "^8.1.4",
        "vitest": "^4.1.10",
        "vue-tsc": "^3.3.7"
    },
    "overrides": {
        "qs": "6.15.3"
    }
}
