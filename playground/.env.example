# Local development environment. Copy to `.env` and adjust.
#
# These values are read through Vite's `import.meta.env` ONLY during local
# development. Deployed artifacts never consume build-time variables; they
# read `runtime-env.json`, rendered at deploy time by
# `scripts/generate-runtime-env.mjs` from the unprefixed equivalents
# (API_URL, APP_URL, ...). Keep the two lists in sync.

VITE_APP_ENV=local
VITE_API_URL=http://localhost:8000
VITE_APP_URL=http://localhost:5173
VITE_DEFAULT_LOCALE=en-US
VITE_ENABLED_LOCALES=["en-US","es-ES","fr-FR"]
# Feature flags delivered at deploy time (unprefixed key: FEATURE_FLAGS in runtime-env.json).
VITE_FEATURE_FLAGS={"new-dashboard":true,"checkout-flow":"b"}
