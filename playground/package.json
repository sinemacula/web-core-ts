{
    "name": "@sinemacula/web-core-playground",
    "version": "1.0.0",
    "description": "Reference application and development harness for @sinemacula/web-core.",
    "private": true,
    "type": "module",
    "license": "Apache-2.0",
    "author": "Sine Macula Limited",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "size": "size-limit"
    },
    "dependencies": {
        "@sinemacula/web-core": "file:..",
        "pinia": "^3.0.4",
        "vee-validate": "^4.15.1",
        "vue": "^3.5.38",
        "vue-i18n": "^11.4.5",
        "vue-router": "^5.1.0",
        "zod": "^4.4.3"
    },
    "size-limit": [
        {
            "name": "application js (gzip)",
            "path": "dist/assets/*.js",
            "limit": "150 KB"
        },
        {
            "name": "application css (gzip)",
            "path": "dist/assets/*.css",
            "limit": "25 KB"
        }
    ]
}
