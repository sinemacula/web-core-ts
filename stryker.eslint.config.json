{
    "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
    "testRunner": "vitest",
    "vitest": {
        "configFile": "eslint/vitest.config.mjs"
    },
    "ignorePatterns": [
        ".idea",
        ".qlty",
        ".sinemacula",
        "build",
        "coverage",
        "dist",
        "e2e",
        "playground",
        "src",
        "test-results"
    ],
    "mutate": ["eslint/rules/**/*.js", "!**/__tests__/**"],
    "thresholds": {
        "high": 90,
        "low": 85,
        "break": 85
    },
    "reporters": ["clear-text", "progress", "html"],
    "htmlReporter": {
        "fileName": "build/mutation/mutation-eslint.html"
    },
    "tempDirName": ".stryker-tmp-eslint"
}
