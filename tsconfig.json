{
    "extends": "@sinemacula/coding-standards/js/tsconfig.base.json",
    "compilerOptions": {
        "lib": ["ES2023", "DOM", "DOM.Iterable"],
        "jsx": "preserve",
        "jsxImportSource": "vue",
        "paths": {
            "@/*": ["./playground/src/*"]
        },
        "types": ["vite/client", "node"],
        "noEmit": true
    },
    "include": ["src", "playground", "e2e", "vitest.config.ts", "playwright.config.ts", "knip.ts"],
    "exclude": ["node_modules", "dist", "coverage", "playground/dist"]
}
