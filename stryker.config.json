{
    "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
    "testRunner": "vitest",
    "ignorePatterns": [
        ".idea",
        ".qlty",
        ".sinemacula",
        "build",
        "coverage",
        "dist",
        "e2e",
        "playground/dist",
        "playground/public",
        "test-results"
    ],
    "mutate": [
        "src/**/*.ts",
        "playground/src/**/*.ts",
        "!**/*.test.ts",
        "!**/test-support/**",
        "!**/index.ts",
        "!playground/src/main.ts",
        "!**/locales/**"
    ],
    "thresholds": {
        "high": 95,
        "low": 90,
        "break": 90
    },
    "reporters": [
        "clear-text",
        "progress",
        "html"
    ],
    "htmlReporter": {
        "fileName": "build/mutation/mutation.html"
    },
    "tempDirName": ".stryker-tmp"
}
